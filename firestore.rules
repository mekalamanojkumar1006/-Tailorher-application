rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // Role Helpers
    function isTailor() {
      return isSignedIn() && (
        request.auth.token.email == 'mekalamanojkumar6@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['tailor', 'admin'])
      );
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Users ---
    function isValidUser(data) {
      return data.uid is string && data.uid.size() <= 128 &&
             data.role in ['customer', 'tailor', 'admin'] &&
             data.teluguEnabled is bool &&
             (data.get('email', '') is string && data.get('email', '').size() <= 256) &&
             (data.get('displayName', '') is string && data.get('displayName', '').size() <= 256) &&
             (data.get('createdAt', request.time) is timestamp);
    }

    match /users/{userId} {
      allow get: if isValidId(userId) && (isOwner(userId) || isTailor());
      allow list: if isTailor();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().role == existing().role;
    }

    // --- Orders ---
    function isValidOrder(data) {
      return (data.get('customerId', '') is string && data.get('customerId', '').size() <= 128) &&
             (data.get('serviceId', '') is string && data.get('serviceId', '').size() <= 128) &&
             (data.get('status', 'pending') in ['pending', 'received', 'cutting', 'stitching', 'finishing', 'ready', 'delivered', 'cancelled', 'paid']) &&
             (data.get('measurements', {}) is map) &&
             (data.get('totalPrice', 0) is number) &&
             (data.get('paymentStatus', 'pending') in ['pending', 'success', 'failed', 'cod']) &&
             (data.get('materialCost', 0) is number) &&
             (data.get('serviceCost', 0) is number) &&
             (data.get('pickupRequired', false) is bool) &&
             (data.get('updatedAt', request.time) is timestamp) &&
             (data.get('paidAt', request.time) is timestamp || data.get('paidAt', null) == null);
    }

    match /orders/{orderId} {
      allow get: if isValidId(orderId) && (isOwner(existing().customerId) || isTailor());
      allow list: if isSignedIn() && (resource.data.customerId == request.auth.uid || isTailor());
      allow create: if isSignedIn() && 
                    incoming().customerId == request.auth.uid &&
                    isValidOrder(incoming()) &&
                    incoming().status == 'pending' &&
                    incoming().createdAt == request.time;
      allow update: if isSignedIn() && isValidOrder(incoming()) && (
        // Tailor can update status and pricing
        (isTailor() && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'serviceCost', 'materialCost', 'totalPrice', 'updatedAt'])) ||
        // Owner can pay
        (isOwner(existing().customerId) && 
         incoming().diff(existing()).affectedKeys().hasOnly(['status', 'paymentStatus', 'paidAt', 'updatedAt']) &&
         incoming().status == 'paid' && incoming().paymentStatus == 'success' &&
         incoming().paidAt == request.time) ||
        // Owner can choose COD
        (isOwner(existing().customerId) && 
         incoming().diff(existing()).affectedKeys().hasOnly(['status', 'paymentStatus', 'updatedAt']) &&
         incoming().status == 'received' && incoming().paymentStatus == 'cod') ||
        // Owner can cancel if pending and within 24 hours
        (isOwner(existing().customerId) && existing().status == 'pending' && 
         incoming().status == 'cancelled' &&
         incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']) &&
         request.time < (existing().createdAt + duration.value(24, 'h'))) ||
        // Owner can update measurements only if pending
        (isOwner(existing().customerId) && existing().status == 'pending' && 
         incoming().diff(existing()).affectedKeys().hasOnly(['measurements', 'updatedAt']))
      );
    }

    // --- Measurements ---
    function isValidMeasurement(data) {
       return data.customerId is string && data.customerId == request.auth.uid &&
              data.data is map && data.get('label', '') is string;
    }

    match /measurements/{mId} {
      allow read: if isValidId(mId) && (isOwner(resource.data.customerId) || isTailor());
      allow create: if isSignedIn() && isValidMeasurement(incoming());
      allow update: if isSignedIn() && isOwner(existing().customerId) && isValidMeasurement(incoming());
      allow delete: if isSignedIn() && isOwner(existing().customerId);
    }

    // --- Services ---
    match /services/{sId} {
      allow read: if true;
      allow write: if isTailor();
    }

    // --- Designs ---
    match /designs/{dId} {
      allow read: if true;
      allow write: if isTailor();
    }

    // --- Feedbacks ---
    function isValidFeedback(data) {
      return data.customerId is string && data.customerId == request.auth.uid &&
             data.orderId is string &&
             data.comment is string && data.comment.size() <= 1000 &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             data.createdAt == request.time;
    }

    match /feedbacks/{fId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidFeedback(incoming()) && exists(/databases/$(database)/documents/orders/$(incoming().orderId));
      allow delete: if isSignedIn() && isOwner(existing().customerId);
    }

    // --- Design Overrides ---
    match /design_overrides/{dId} {
      allow read: if true;
      allow write: if isTailor();
    }

    // --- Settings ---
    match /settings/{sId} {
      allow read: if true; // Customers need to read payment settings for QR
      allow write: if isTailor();
    }
  }
}
