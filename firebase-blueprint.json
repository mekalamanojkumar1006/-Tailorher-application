{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["customer", "tailor"] },
        "teluguEnabled": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Order": {
      "title": "Order",
      "description": "Tailoring order details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerId": { "type": "string" },
        "serviceId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "received", "stitching", "ready", "delivered"] },
        "measurements": { "type": "object" },
        "designImageUrl": { "type": "string" },
        "totalPrice": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerId", "serviceId", "status", "measurements"]
    },
    "Measurement": {
      "title": "Measurement",
      "description": "Customer body measurements",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerId": { "type": "string" },
        "label": { "type": "string" },
        "data": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerId", "data"]
    },
    "Service": {
      "title": "Service",
      "description": "Tailoring services offered",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "object" },
        "description": { "type": "object" },
        "basePrice": { "type": "number" },
        "category": { "type": "string" }
      }
    },
    "Design": {
      "title": "Design",
      "description": "Fashion design inspirations",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "object" },
        "imageUrl": { "type": "string" },
        "category": { "type": "string" }
      }
    },
    "Feedback": {
      "title": "Feedback",
      "description": "Customer feedback and reviews",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "orderId": { "type": "string" },
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "comment": { "type": "string" },
        "rating": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["orderId", "customerId", "comment", "rating"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles"
    },
    "orders/{orderId}": {
      "schema": "Order",
      "description": "Collection of tailoring orders"
    },
    "measurements/{measurementId}": {
      "schema": "Measurement",
      "description": "Collection of body measurements"
    },
    "services/{serviceId}": {
      "schema": "Service",
      "description": "Available tailoring services"
    },
    "designs/{designId}": {
      "schema": "Design",
      "description": "Gallery of dress designs"
    },
    "feedbacks/{feedbackId}": {
      "schema": "Feedback",
      "description": "Collection of customer feedbacks"
    },
    "design_overrides/{designId}": {
      "schema": {
        "title": "Design Override",
        "description": "Custom pricing for gallery designs",
        "type": "object",
        "properties": {
          "price": { "type": "number" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "description": "Tailor defined custom prices for designs"
    },
    "settings/{settingId}": {
      "schema": {
        "title": "App Settings",
        "description": "Global application configuration",
        "type": "object",
        "properties": {
          "upiId": { "type": "string" },
          "bankName": { "type": "string" },
          "accountNumber": { "type": "string" },
          "ifscCode": { "type": "string" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "description": "Collection for tailor setting like payment details"
    }
  }
}
